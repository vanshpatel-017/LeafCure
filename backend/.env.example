# Backend environment variables
# Copy this file to backend/.env and fill in the values with your actual configuration

# Firebase Configuration
# Get these from your Firebase Console at https://console.firebase.google.com
# FIREBASE_WEB_API_KEY is used for frontend authentication
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# Path to Firebase service account JSON (optional - defaults to ./service-account.json)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=

# CORS Configuration (comma-separated list of allowed origins)
# Add your frontend URLs here
# Example: http://localhost:5173,https://myapp.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security Settings
# Set to 'production' in production environments
ENVIRONMENT=development

# API Settings
# Host and port for the API server
API_HOST=0.0.0.0
API_PORT=8000

